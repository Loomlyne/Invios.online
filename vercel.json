{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/recurring",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/pdf-keepalive",
      "schedule": "*/5 * * * *"
    }
  ]
}
